# Base URL of the Serble API (no trailing slash)
VITE_API_URL=https://api.serble.net/api/v1

# Set to "true" to disable the Cloudflare Turnstile captcha and send
# "bypass testing" as the SerbleAntiSpam header instead. For local
# testing only — the API must accept the bypass token.
VITE_DISABLE_TURNSTILE=false
